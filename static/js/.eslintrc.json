    "getSelectedRomProject": "readonly",
    "switchAppView": "readonly",
    "checkEnv": "readonly",
    "loadProjectImages": "readonly",
    "refreshRomList": "readonly",
    "refreshExtractedRoms": "readonly",
    "loadVbmetaRomList": "readonly",
    "updateResumeCard": "readonly",
    "restoreBackendBatchTaskIfRunning": "readonly",
    "pollTaskFallback": "readonly",
